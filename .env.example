# Model provider: openai or azure_openai.
MCP_PORTAL_MODEL_PROVIDER=azure_openai

# Direct OpenAI platform settings. OPENAI_API_KEY is only used with
# MCP_PORTAL_MODEL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_LARGE_LANGUAGE_MODEL=gpt-5.5
OPENAI_SMALL_LANGUAGE_MODEL=gpt-5.5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Azure OpenAI uses Azure Identity / RBAC, not API keys.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default
AZURE_OPENAI_LARGE_LANGUAGE_MODEL_DEPLOYMENT=
AZURE_OPENAI_SMALL_LANGUAGE_MODEL_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_MODEL_DEPLOYMENT=

# Optional service-principal credentials consumed by Azure Identity.
# Leave blank when using managed identity, Azure CLI auth, workload identity, etc.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

MCP_PORTAL_HEALTH_ENABLED=true

# Production HTTP / ASGI
MCP_PORTAL_HTTP_PATH=/mcp
MCP_PORTAL_HEALTH_PATH=/healthz
MCP_PORTAL_READINESS_PATH=/readyz
MCP_PORTAL_JSON_RESPONSE=
MCP_PORTAL_STATELESS_HTTP=

# Auth: none, static, jwt, ldap, kerberos, or ldap+kerberos.
MCP_PORTAL_AUTH_PROVIDER=none
MCP_PORTAL_AUTH_REQUIRED_SCOPES=
MCP_PORTAL_AUTH_STATIC_TOKEN=
MCP_PORTAL_AUTH_STATIC_CLIENT_ID=mcp-portal-static
MCP_PORTAL_AUTH_STATIC_SCOPES=
MCP_PORTAL_AUTH_JWT_PUBLIC_KEY=
MCP_PORTAL_AUTH_JWT_JWKS_URI=
MCP_PORTAL_AUTH_JWT_ISSUER=
MCP_PORTAL_AUTH_JWT_AUDIENCE=
MCP_PORTAL_AUTH_JWT_ALGORITHM=RS256
MCP_PORTAL_AUTH_RESOURCE_SERVER_URL=

# LDAP Basic authentication. Use LDAPS, or ldap:// with START_TLS=true.
MCP_PORTAL_AUTH_LDAP_URI=
MCP_PORTAL_AUTH_LDAP_BASE_DN=
MCP_PORTAL_AUTH_LDAP_USER_DN_TEMPLATE=
MCP_PORTAL_AUTH_LDAP_SEARCH_FILTER=(uid={username})
MCP_PORTAL_AUTH_LDAP_BIND_DN=
MCP_PORTAL_AUTH_LDAP_BIND_PASSWORD=
MCP_PORTAL_AUTH_LDAP_START_TLS=false
MCP_PORTAL_AUTH_LDAP_CA_CERT_FILE=
MCP_PORTAL_AUTH_LDAP_CONNECT_TIMEOUT=5
MCP_PORTAL_AUTH_LDAP_SCOPES=

# Kerberos HTTP Negotiate authentication. On Linux, KEYTAB initializes KRB5_KTNAME.
MCP_PORTAL_AUTH_KERBEROS_HOSTNAME=
MCP_PORTAL_AUTH_KERBEROS_SERVICE=HTTP
MCP_PORTAL_AUTH_KERBEROS_KEYTAB=
MCP_PORTAL_AUTH_KERBEROS_SCOPES=
MCP_PORTAL_AUTHZ_TAG_SCOPES=admin=admin;destructive=admin;external=external;write=write
MCP_PORTAL_AUTHZ_NAMESPACE_SCOPES=

# Production middleware
MCP_PORTAL_MIDDLEWARE_ENABLED=false
MCP_PORTAL_STRUCTURED_LOGGING=true
MCP_PORTAL_LOG_PAYLOAD_LENGTHS=true
MCP_PORTAL_RATE_LIMIT_PER_SECOND=25
MCP_PORTAL_RATE_LIMIT_BURST=50
MCP_PORTAL_RESPONSE_MAX_BYTES=1000000

# Namespace discovery
MCP_PORTAL_NAMESPACE_DISCOVERY_STRICT=false

# SQLAlchemy is enforced for database access. Oracle is the preferred backend.
MCP_PORTAL_DATABASE_PROVIDER=oracle
MCP_PORTAL_DATABASE_SQLALCHEMY_URL=
MCP_PORTAL_ORACLE_DSN=
MCP_PORTAL_ORACLE_USER=
MCP_PORTAL_ORACLE_PASSWORD=
MCP_PORTAL_ORACLE_POOL_MIN=1
MCP_PORTAL_ORACLE_POOL_MAX=4

# LangChain MongoDB connectors are independent of the SQLAlchemy provider.
MCP_PORTAL_LANGCHAIN_MONGODB_CONNECTION_STRING=
MCP_PORTAL_LANGCHAIN_MONGODB_DATABASE=
MCP_PORTAL_LANGCHAIN_MONGODB_VECTOR_SEARCH_INDEX=vector_index

# OpenTelemetry export can be enabled by launching with opentelemetry-instrument.
OTEL_SERVICE_NAME=mcp-portal
OTEL_EXPORTER_OTLP_ENDPOINT=

# Enterprise control plane
MCP_PORTAL_PRODUCTION_REQUIRE_AUTH=false
MCP_PORTAL_REQUIRE_TENANT=false
MCP_PORTAL_TENANT_CLAIM=tenant_id
MCP_PORTAL_AUDIT_ENABLED=true
MCP_PORTAL_TOOL_TIMEOUT_SECONDS=45
# Semicolon-separated fully-qualified tool overrides.
MCP_PORTAL_TOOL_TIMEOUT_OVERRIDES=
MCP_PORTAL_MAX_CONCURRENT_REQUESTS=100
MCP_PORTAL_TOOL_CONCURRENCY_LIMITS=
MCP_PORTAL_DOWNSTREAM_TIMEOUT_SECONDS=45
MCP_PORTAL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
MCP_PORTAL_CIRCUIT_BREAKER_RECOVERY_SECONDS=30
MCP_PORTAL_TASK_MAX_TTL_SECONDS=3600
MCP_PORTAL_TASK_MAX_CONCURRENT_PER_SUBJECT=10
MCP_PORTAL_EGRESS_ALLOWED_HOSTS=
MCP_PORTAL_NAMESPACE_ALLOWLIST=
