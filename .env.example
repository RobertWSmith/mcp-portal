OPENAI_API_KEY=your-api-key
OPENAI_LARGE_LANGUAGE_MODEL=gpt-5.5
OPENAI_SMALL_LANGUAGE_MODEL=gpt-5.5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
MCP_PORTAL_HEALTH_ENABLED=true

# Production HTTP / ASGI
MCP_PORTAL_HTTP_PATH=/mcp
MCP_PORTAL_HEALTH_PATH=/healthz
MCP_PORTAL_JSON_RESPONSE=
MCP_PORTAL_STATELESS_HTTP=

# Auth: none, static, or jwt. Prefer jwt/JWKS for production.
MCP_PORTAL_AUTH_PROVIDER=none
MCP_PORTAL_AUTH_REQUIRED_SCOPES=
MCP_PORTAL_AUTH_STATIC_TOKEN=
MCP_PORTAL_AUTH_STATIC_CLIENT_ID=mcp-portal-static
MCP_PORTAL_AUTH_STATIC_SCOPES=
MCP_PORTAL_AUTH_JWT_PUBLIC_KEY=
MCP_PORTAL_AUTH_JWT_JWKS_URI=
MCP_PORTAL_AUTH_JWT_ISSUER=
MCP_PORTAL_AUTH_JWT_AUDIENCE=
MCP_PORTAL_AUTH_JWT_ALGORITHM=RS256
MCP_PORTAL_AUTHZ_TAG_SCOPES=admin=admin;destructive=admin;external=external;write=write

# Production middleware
MCP_PORTAL_MIDDLEWARE_ENABLED=false
MCP_PORTAL_STRUCTURED_LOGGING=true
MCP_PORTAL_LOG_PAYLOAD_LENGTHS=true
MCP_PORTAL_RATE_LIMIT_PER_SECOND=25
MCP_PORTAL_RATE_LIMIT_BURST=50
MCP_PORTAL_RESPONSE_MAX_BYTES=1000000

# Namespace discovery
MCP_PORTAL_NAMESPACE_DISCOVERY_STRICT=false

# SQLAlchemy is enforced for database access. Oracle is the preferred backend.
MCP_PORTAL_DATABASE_PROVIDER=oracle
MCP_PORTAL_DATABASE_SQLALCHEMY_URL=
MCP_PORTAL_ORACLE_DSN=
MCP_PORTAL_ORACLE_USER=
MCP_PORTAL_ORACLE_PASSWORD=
MCP_PORTAL_ORACLE_POOL_MIN=1
MCP_PORTAL_ORACLE_POOL_MAX=4

# OpenTelemetry export can be enabled by launching with opentelemetry-instrument.
OTEL_SERVICE_NAME=mcp-portal
OTEL_EXPORTER_OTLP_ENDPOINT=
